<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Title -->
        <TextView
            android:id="@+id/titleTv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Android Developer Intern"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#212121"/>

        <!-- Company -->
        <TextView
            android:id="@+id/companyTv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Google"
            android:textSize="18sp"
            android:textColor="#424242"/>

        <!-- Location -->
        <TextView
            android:id="@+id/locationTv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Remote"
            android:textSize="16sp"
            android:textColor="#757575"/>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="16dp"
            android:background="#E0E0E0"/>

        <!-- Salary -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Salary"
            android:textStyle="bold"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/salaryTv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹25,000/month"
            android:textSize="16sp"
            android:layout_marginTop="2dp"/>

        <!-- Experience -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Experience Required"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/experienceTv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0-1 years"
            android:textSize="16sp"
            android:layout_marginTop="2dp"/>

        <!-- Description -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Job Description"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="20dp"/>

        <TextView
            android:id="@+id/descriptionTv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="You will work on Android applications using Kotlin and modern Android architecture."
            android:textSize="15sp"
            android:layout_marginTop="4dp"
            android:lineSpacingExtra="2dp"/>

        <!-- Apply Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/applyBtn"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="30dp"
            android:text="Apply Now"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            app:backgroundTint="#6200EE"
            app:cornerRadius="12dp"/>

    </LinearLayout>

</ScrollView>